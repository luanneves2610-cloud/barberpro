# ============================================================
# BarberPro — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Banco de dados (Prisma) ───────────────────────────────────
# Pooler (para queries normais via Prisma)
DATABASE_URL=postgresql://postgres.SEU_PROJETO:SENHA@aws-1-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Conexão direta (para migrations)
DIRECT_URL=postgresql://postgres.SEU_PROJETO:SENHA@aws-1-sa-east-1.pooler.supabase.com:5432/postgres

# ── App ───────────────────────────────────────────────────────
# URL pública do app (usado em links de avaliação e QR codes)
NEXT_PUBLIC_APP_URL=https://app.seudominio.com.br

# ── Redis / BullMQ ────────────────────────────────────────────
# Local: redis://localhost:6379
# Upstash: rediss://default:SENHA@ENDPOINT.upstash.io:6379
REDIS_URL=redis://localhost:6379

# ── WhatsApp — Evolution API ──────────────────────────────────
# Self-hosted: https://github.com/EvolutionAPI/evolution-api
EVOLUTION_API_URL=https://sua-evolution.seudominio.com.br
EVOLUTION_API_KEY=sua_api_key_aqui
EVOLUTION_INSTANCE=barberpro

# ── Mercado Pago ──────────────────────────────────────────────
# Credenciais em: https://www.mercadopago.com.br/developers
MERCADOPAGO_ACCESS_TOKEN=APP_USR-...
MERCADOPAGO_WEBHOOK_SECRET=sua_chave_secreta_webhook

# ── Focus NFe ─────────────────────────────────────────────────
# Conta em: https://focusnfe.com.br
FOCUS_NFE_TOKEN=seu_token_aqui
# "homologacao" para testes, "producao" para emissão real
FOCUS_NFE_ENV=homologacao

# ── Next.js ───────────────────────────────────────────────────
# Apenas em desenvolvimento (gerado automaticamente em produção)
# NEXTAUTH_SECRET=
